{
    "name": "vive-realestate",
    "version": "1.0.0",
    "private": true,
    "workspaces": [
        "frontend",
        "backend"
    ],
    "scripts": {
        "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
        "dev:frontend": "npm run dev --workspace=frontend",
        "dev:backend": "npm run start:dev --workspace=backend",
        "build": "npm run build --workspaces",
        "test": "npm run test --workspaces",
        "lint": "npm run lint --workspaces",
        "format": "prettier --write \"**/*.{ts,tsx,md}\"",
        "version:frontend": "npm version --workspace=frontend",
        "version:backend": "npm version --workspace=backend",
        "release:frontend": "npm run build --workspace=frontend && npm run version:frontend",
        "release:backend": "npm run build --workspace=backend && npm run version:backend"
    },
    "devDependencies": {
        "concurrently": "^8.2.2",
        "prettier": "^3.1.1"
    }
}